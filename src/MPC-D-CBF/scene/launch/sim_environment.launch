<?xml version="1.0"?>

<launch>
  <arg name="world" default="$(find scene)/worlds/world.world" />
  <arg name="spawn_x" default="-10.0" />
  <arg name="spawn_y" default="0.0" />
  <arg name="spawn_z" default="1.0" />
  <arg name="enable_fov_filter" default="true" />
  <arg name="fov_deg" default="70.0" />
  <arg name="fov_range_min" default="0.2" />
  <arg name="fov_range_max" default="7.0" />
  <arg name="publish_fov_marker" default="true" />

  <include file="$(find scene)/launch/start.launch">
    <arg name="world" value="$(arg world)" />
    <arg name="gui" value="false" />
  </include>

  <include file="$(find jackal_description)/launch/description.launch" />
  <include file="$(find jackal_control)/launch/control.launch">
    <arg name="enable_ekf" value="false" />
  </include>
  <include file="$(find jackal_control)/launch/teleop.launch">
    <arg name="joystick" value="false" />
  </include>

  <node
    name="urdf_spawner"
    pkg="gazebo_ros"
    type="spawn_model"
    args="-urdf -model jackal -param robot_description -x $(arg spawn_x) -y $(arg spawn_y) -z $(arg spawn_z)" />

  <include file="$(find local_map)/launch/for_simulation.launch">
    <arg name="enable_fov_filter" value="$(arg enable_fov_filter)" />
    <arg name="fov_deg" value="$(arg fov_deg)" />
    <arg name="fov_range_min" value="$(arg fov_range_min)" />
    <arg name="fov_range_max" value="$(arg fov_range_max)" />
    <arg name="publish_fov_marker" value="$(arg publish_fov_marker)" />
  </include>
  <include file="$(find scene)/launch/movetest_node.launch" />
  <node pkg="obs_param" type="obs_kf" output="screen" name="obs_kf" />
  <include file="$(find global_path_publisher)/launch/pub_global_path.launch" />
</launch>
