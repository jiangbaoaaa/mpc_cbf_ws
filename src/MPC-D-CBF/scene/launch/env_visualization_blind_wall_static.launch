<?xml version="1.0"?>

<launch>
  <arg name="world" default="$(find scene)/worlds/blind_wall_static.world" />
  <arg name="spawn_x" default="-5.5" />
  <arg name="spawn_y" default="0.0" />
  <arg name="spawn_z" default="1.0" />
  <arg name="global_path_start_x" default="-5.5" />
  <arg name="global_path_start_y" default="0.0" />
  <arg name="global_path_end_x" default="1.65" />
  <arg name="global_path_end_y" default="0.35" />
  <arg name="global_path_waypoints" default="-5.5,0.0;-2.4,0.0;-1.15,0.05;-0.55,0.26;-0.18,0.72;0.08,1.02;0.52,1.22;1.02,1.24;1.38,0.98;1.58,0.68;1.65,0.35" />
  <arg name="global_path_step" default="0.06" />
  <arg name="global_path_smooth" default="true" />
  <arg name="show_gazebo_global_path" default="true" />
  <arg name="gazebo_global_path_stride" default="4" />
  <arg name="spawn_goal_marker" default="false" />
  <arg name="goal_marker_x" default="$(arg global_path_end_x)" />
  <arg name="goal_marker_y" default="$(arg global_path_end_y)" />
  <arg name="goal_marker_z" default="0.0" />
  <arg name="use_rviz" default="true" />
  <arg name="use_gazebo_gui" default="true" />
  <arg name="localmap_x_size" default="18" />
  <arg name="localmap_y_size" default="18" />
  <arg name="enable_fov_filter" default="true" />
  <arg name="fov_deg" default="70.0" />
  <arg name="fov_range_min" default="0.2" />
  <arg name="fov_range_max" default="7.0" />
  <arg name="publish_fov_marker" default="true" />

  <include file="$(find scene)/launch/sim_environment.launch">
    <arg name="world" value="$(arg world)" />
    <arg name="spawn_x" value="$(arg spawn_x)" />
    <arg name="spawn_y" value="$(arg spawn_y)" />
    <arg name="spawn_z" value="$(arg spawn_z)" />
    <arg name="global_path_start_x" value="$(arg global_path_start_x)" />
    <arg name="global_path_start_y" value="$(arg global_path_start_y)" />
    <arg name="global_path_end_x" value="$(arg global_path_end_x)" />
    <arg name="global_path_end_y" value="$(arg global_path_end_y)" />
    <arg name="global_path_waypoints" value="$(arg global_path_waypoints)" />
    <arg name="global_path_step" value="$(arg global_path_step)" />
    <arg name="global_path_smooth" value="$(arg global_path_smooth)" />
    <arg name="show_gazebo_global_path" value="$(arg show_gazebo_global_path)" />
    <arg name="gazebo_global_path_stride" value="$(arg gazebo_global_path_stride)" />
    <arg name="spawn_goal_marker" value="$(arg spawn_goal_marker)" />
    <arg name="goal_marker_x" value="$(arg goal_marker_x)" />
    <arg name="goal_marker_y" value="$(arg goal_marker_y)" />
    <arg name="goal_marker_z" value="$(arg goal_marker_z)" />
    <arg name="localmap_x_size" value="$(arg localmap_x_size)" />
    <arg name="localmap_y_size" value="$(arg localmap_y_size)" />
    <arg name="use_obstacle_node" value="false" />
    <arg name="enable_fov_filter" value="$(arg enable_fov_filter)" />
    <arg name="fov_deg" value="$(arg fov_deg)" />
    <arg name="fov_range_min" value="$(arg fov_range_min)" />
    <arg name="fov_range_max" value="$(arg fov_range_max)" />
    <arg name="publish_fov_marker" value="$(arg publish_fov_marker)" />
  </include>

  <include file="$(find scene)/launch/visualization.launch">
    <arg name="use_rviz" value="$(arg use_rviz)" />
    <arg name="use_gazebo_gui" value="$(arg use_gazebo_gui)" />
  </include>
</launch>
